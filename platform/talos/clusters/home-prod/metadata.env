# Cluster metadata - non-secret values committed to Git

# Cluster identity
CLUSTER_NAME="home-prod"
DOMAIN="lab.home.arpa"

# Control plane node IPs (DHCP reservations - create these before Talos installation)
CP_01_IP="192.168.1.21"
CP_02_IP="192.168.1.22"
CP_03_IP="192.168.1.23"

# Cluster endpoint (DNS A record - initially points to cp-01: 192.168.1.21)
# VIP/load balancer can be added later after control plane is healthy
CLUSTER_ENDPOINT="k8s.lab.home.arpa"

# Talos install disk (confirm with: talosctl get disks --insecure --nodes <CP_01_IP>)
INSTALL_DISK="/dev/nvme0n1"

# Network configuration
# MAC addresses: Document locally when creating DHCP reservations, do not commit to Git
NETWORK_INTERFACE="TBD"  # Confirm via: talosctl get --insecure --nodes <IP> links after Talos boot
DNS_SERVERS="192.168.1.1,1.1.1.1"
NTP_SERVERS="pool.ntp.org"
DEFAULT_GATEWAY="192.168.1.1"
API_ACCESS_CIDR="192.168.1.0/24"

# Platform versions (provisional - verify compatibility before config generation)
TALOS_VERSION="v1.8.0"
KUBERNETES_VERSION="v1.31.0"

# CNI choice
CNI_PLUGIN="cilium"

# Hardware notes
CONTROL_PLANE_NODES="3 x Intel i5 GMKtec mini PCs, 16 GB RAM each, 1 TB NVMe each"
WORKER_NODES="0 initially"
