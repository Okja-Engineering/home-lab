# Cluster metadata - non-secret values committed to Git

# Cluster identity
CLUSTER_NAME="home-lab"
DOMAIN="lab.home.arpa"

# Control plane node IPs (DHCP reservations)
CP01_IP="192.168.1.21"
CP02_IP="192.168.1.22"
CP03_IP="192.168.1.23"

# Cluster endpoint (DNS name - configure VIP or load balancer to point to this)
CLUSTER_ENDPOINT="k8s.lab.home.arpa"

# Talos install disk (confirm with: talosctl get disks --insecure --nodes <CP01_IP>)
INSTALL_DISK="/dev/nvme0n1"

# Network configuration
NETWORK_INTERFACE="TBD"  # Determine after first Talos boot (likely eth0 or enp1s0)
DNS_SERVERS="192.168.1.1,1.1.1.1"
NTP_SERVERS="pool.ntp.org"
DEFAULT_GATEWAY="192.168.1.1"
API_ACCESS_CIDR="192.168.1.0/24"

# Platform versions
TALOS_VERSION="v1.8.0"
KUBERNETES_VERSION="v1.31.0"

# CNI choice
CNI_PLUGIN="cilium"

# Hardware notes
CONTROL_PLANE_NODES="3 x Intel i5 GMKtec mini PCs, 16 GB RAM each, 1 TB NVMe each"
WORKER_NODES="0 initially"
